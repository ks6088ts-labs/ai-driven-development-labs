# ---------
# Grafana authentication
# Copy this file to .env and fill in your values.
# .env is excluded from version control via .gitignore.
# ---------

# Initial password for the Grafana admin account (login: admin).
# Change this before deploying even in a local environment.
GF_SECURITY_ADMIN_PASSWORD=changeme

# Password for the provisioned viewer account (login: viewer).
GF_VIEWER_PASSWORD=viewerpass

{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "jaeger", "name": "Jaeger", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "traces", "name": "Traces", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "IMU sensor telemetry: accelerometer, gyroscope, read-latency heatmap, and traces.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "m/s²",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "accMS2"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "last", "max", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_accel_x_meters_per_s2{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "accel_x (handle={{sensor_handle}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_accel_y_meters_per_s2{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "accel_y (handle={{sensor_handle}})",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_accel_z_meters_per_s2{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "accel_z (handle={{sensor_handle}})",
          "refId": "C"
        }
      ],
      "title": "Accelerometer (x / y / z)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "rad/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "raduS"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "last", "max", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_gyro_x_rad_per_second{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "gyro_x (handle={{sensor_handle}})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_gyro_y_rad_per_second{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "gyro_y (handle={{sensor_handle}})",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "imu_gyro_z_rad_per_second{sensor_handle=~\"$sensor_handle\",sensor_type=~\"$sensor_type\"}",
          "legendFormat": "gyro_z (handle={{sensor_handle}})",
          "refId": "C"
        }
      ],
      "title": "Gyroscope (x / y / z)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "scheme": "Spectral" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "scaleDistribution": { "log": 2, "type": "log" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "min": 0,
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "showColorScale": false, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "min": 0, "unit": "ms", "reverse": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
          "expr": "sum(increase(imu_read_latency_milliseconds_bucket[$__rate_interval])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "IMU Read Latency Heatmap",
      "type": "heatmap"
    },
    {
      "datasource": { "type": "jaeger", "uid": "${datasource_jaeger}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "jaeger", "uid": "${datasource_jaeger}" },
          "limit": 20,
          "operation": "imu.read",
          "queryType": "search",
          "refId": "A",
          "service": "imu-cli"
        }
      ],
      "title": "Recent IMU Traces (Jaeger)",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["imu", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "definition": "label_values({__name__=~\"imu_(accel|gyro)_x_.*\"}, sensor_handle)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Sensor Handle",
        "multi": true,
        "name": "sensor_handle",
        "options": [],
        "query": {
          "query": "label_values({__name__=~\"imu_(accel|gyro)_x_.*\"}, sensor_handle)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource_prometheus}" },
        "definition": "label_values({__name__=~\"imu_(accel|gyro)_x_.*\"}, sensor_type)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Sensor Type",
        "multi": true,
        "name": "sensor_type",
        "options": [],
        "query": {
          "query": "label_values({__name__=~\"imu_(accel|gyro)_x_.*\"}, sensor_type)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "datasource_prometheus",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "datasource_jaeger",
        "options": [],
        "query": "jaeger",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IMU Sensor Dashboard",
  "uid": "imu-sensor-dashboard",
  "version": 1,
  "weekStart": ""
}
